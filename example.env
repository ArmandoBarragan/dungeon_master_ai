# Application
APP_HOST=0.0.0.0
APP_PORT=8001
PYTHONPATH=app

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL (used by docker-compose for the db service)
POSTGRES_USER=dungeon_master
POSTGRES_PASSWORD=dungeon_master_password
POSTGRES_DB=dungeon_master
POSTGRES_HOST=db
POSTGRES_PORT=5432

# App database connection (use localhost when running outside Docker)
DATABASE_URL=postgresql://dungeon_master:dungeon_master_password@db:5432/dungeon_master

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
